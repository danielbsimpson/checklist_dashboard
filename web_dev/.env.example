# Supabase credentials — copy this file to .env and fill in your values.
# The .env file is gitignored and should NEVER be committed.
#
# These values are read at runtime via expo-secure-store (mobile) and
# process.env (web). See src/db.ts for how they are loaded.
#
# Get these from: Supabase dashboard → Settings → API

EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY
